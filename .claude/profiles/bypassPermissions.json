{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_description": "BypassPermissions (YOLO) mode - auto-approves everything EXCEPT deny rules. Deny list is the only safety net. Use only in isolated environments: testnet repos, containers, sandboxes, scratch branches. Allow list is documentation-only; missing entries still auto-approve unless explicitly denied.",
  "_safety_notes": [
    "Deny list is IDENTICAL to acceptEdits.json - keep it that way. Deny rules are the only fence in bypass mode.",
    "Always work on a feature branch (git checkout -b testnet-yolo) so git reset --hard can undo anything.",
    "Consider running inside a container/VM for filesystem isolation. See github.com/con/yolo for podman-based setup.",
    "Do NOT use this profile on main branches or production repos."
  ],
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "NotebookEdit",
      "TodoWrite",
      "WebSearch",
      "WebFetch",
      "Bash"
    ],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(./secrets/**)",
      "Read(**/secrets/**)",
      "Read(./credentials/**)",
      "Read(**/credentials/**)",
      "Read(**/credentials.json)",
      "Read(**/serviceAccount*.json)",
      "Read(**/service-account*.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ecdsa.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Read(~/.config/gh/**)",
      "Read(~/Library/Keychains/**)",
      "Read(./.git/config)",
      "Read(../**)",
      "Read(**/*.secret)",
      "Read(**/signing-key*)",
      "Read(**/private-key*)",
      "Write(./CLAUDE.md)",
      "Edit(./CLAUDE.md)",
      "Write(./.git/**)",
      "Edit(./.git/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(../**)",
      "Edit(../**)",
      "Write(./.github/workflows/**)",
      "Edit(./.github/workflows/**)",
      "Write(./infra/**)",
      "Edit(./infra/**)",
      "Write(./terraform/**)",
      "Edit(./terraform/**)",
      "Write(./k8s/**)",
      "Edit(./k8s/**)",
      "Write(./kubernetes/**)",
      "Edit(./kubernetes/**)",
      "Write(./deploy/**)",
      "Edit(./deploy/**)",
      "Write(**/Dockerfile)",
      "Edit(**/Dockerfile)",
      "Write(**/docker-compose*.yml)",
      "Edit(**/docker-compose*.yml)",
      "Write(**/docker-compose*.yaml)",
      "Edit(**/docker-compose*.yaml)",
      "Write(**/*.secret)",
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.claude/settings.local.json)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(chown *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf .claude*)",
      "Bash(rm -rf .harness*)",
      "Bash(rm CLAUDE.md*)",
      "Bash(rm .claude*)",
      "Bash(mv .claude*)",
      "Bash(mv CLAUDE.md*)",
      "Bash(mv .harness*)",
      "Bash(ln -s * .claude*)",
      "Bash(ln -s * CLAUDE.md*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --delete*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git merge * main)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(aws iam *)",
      "Bash(aws sts assume-role*)",
      "Bash(aws ec2 run-instances*)",
      "Bash(aws ec2 terminate-instances*)",
      "Bash(aws rds delete-* *)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3api delete-* *)",
      "Bash(aws dynamodb delete-* *)",
      "Bash(aws ecr batch-delete-* *)",
      "Bash(aws cloudformation delete-* *)",
      "Bash(aws secretsmanager *)",
      "Bash(gcloud *)",
      "Bash(az *)",
      "Bash(docker push*)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(twine upload*)",
      "Bash(gem push*)",
      "Bash(prisma db reset*)",
      "Bash(nc -l*)",
      "Bash(ncat *)",
      "Bash(ssh *)",
      "Bash(* && *)",
      "Bash(* ; *)",
      "Bash(* || *)"
    ],
    "defaultMode": "bypassPermissions"
  }
}

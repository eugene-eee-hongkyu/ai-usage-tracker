# ── 환경변수 / 시크릿 ─────────────────────────────
.env
.env.*
!.env.example

# ── macOS ─────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Node / npm ────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*

# ── Next.js ───────────────────────────────────────
web/.next/
web/out/
web/.vercel/
web/next-env.d.ts

# ── TypeScript 빌드 캐시 ──────────────────────────
web/tsconfig.tsbuildinfo
cli/tsconfig.tsbuildinfo


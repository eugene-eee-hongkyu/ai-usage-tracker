{
  "name": "@primus/usage-tracker",
  "version": "0.2.0",
  "description": "Claude Code usage tracker CLI",
  "type": "module",
  "bin": {
    "usage-tracker": "./src/index.mjs"
  },
  "scripts": {
    "build:index": "bun build src/index.ts --outfile src/index.mjs --target node",
    "build:sync": "bun build src/sync.ts --outfile src/sync.mjs --target node",
    "build:init": "bun build src/init.ts --outfile src/init.mjs --target node",
    "build": "bun run build:index && bun run build:sync && bun run build:init",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "keytar": "^7.9.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
